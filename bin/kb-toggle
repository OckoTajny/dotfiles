#!/usr/bin/env bash
# kb-toggle: cycle keyboard layout (us,cz) and notify which one is now active.
# Bound to Super+Space. ponytail: reads main keyboard's active keymap after switch.
export PATH="$HOME/.local/bin:/usr/local/bin:$PATH"

hyprctl switchxkblayout all next >/dev/null 2>&1

name=$(hyprctl devices -j 2>/dev/null \
  | jq -r 'first(.keyboards[] | select(.main==true) | .active_keymap) // empty')
[ -z "$name" ] && name="switched"

notify-send -t 1200 -a keyboard -i input-keyboard "⌨  Keyboard" "$name" 2>/dev/null || true
